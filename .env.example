# ---- Blink account ----
BLINK_USERNAME=your-blink-email@example.com
BLINK_PASSWORD=your-blink-password
# Path where Blink session credentials are cached after the first 2FA login
BLINK_CREDS_FILE=blink_creds.json

# ---- Twilio WhatsApp ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio WhatsApp sender (sandbox default shown). Keep the "whatsapp:" prefix.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Destination number (E.164). Keep the "whatsapp:" prefix.
WHATSAPP_TO=whatsapp:+1XXXXXXXXXX
# Content template SID for motion alerts (HX...). Leave blank to send freeform
# text instead (freeform only delivers within WhatsApp's 24h window).
# Template variables: {{1}}=camera, {{2}}=timestamp, {{3}}=description
TWILIO_CONTENT_SID=

# ---- Telegram fallback (free; works after Twilio credits run out) ----
# Telegram is a free, unlimited fallback channel. It uploads images directly, so
# it does NOT need the tunnel/PUBLIC_BASE_URL that WhatsApp requires.
# Setup: message @BotFather -> /newbot to get TELEGRAM_BOT_TOKEN; then send your
# bot a message and read your chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Delivery strategy: whatsapp_first (default) | telegram_first | both |
# whatsapp_only | telegram_only
NOTIFY_MODE=whatsapp_first

# ---- Monitor settings ----
# How often (seconds) to poll Blink for new motion events
POLL_INTERVAL=15
# Minimum seconds between alerts for the same camera (anti-spam debounce)
ALERT_COOLDOWN=60

# ---- Vision (GitHub Models) ----
# GitHub PAT with Models access. If blank, alerts use a generic description.
GITHUB_TOKEN=
# Vision model on the free GitHub Models endpoint
VISION_MODEL=gpt-4o-mini
# Image detail for vision analysis:
#   low  = ~85 tokens/image, lets us analyse many frames (good for movement)
#   high = sharper; catches facial expressions, gestures, small objects, but
#          costs many more tokens, so pair with a smaller VISION_MAX_FRAMES
#   auto = let the model decide
VISION_DETAIL=low
# Frames-per-second sampled across the WHOLE recorded clip for the vision model
# (the snapshot is always included). Higher = more frames analysed.
CLIP_FPS=2
# Cap on how many clip frames are sent to the vision model (evenly subsampled)
VISION_MAX_FRAMES=16
# Cap on how many frames are attached to the WhatsApp message (evenly subsampled)
MEDIA_MAX_FRAMES=4

# ---- Media attachments (WhatsApp images) ----
# Public base URL where the frames dir is reachable (e.g. an ngrok tunnel).
# Leave blank for text-only alerts. Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=
# Local port the frame media server listens on
MEDIA_PORT=8088
# Directory where captured frames are stored
FRAMES_DIR=frames
